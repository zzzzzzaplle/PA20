    <eLiterals name="GREEN"/>
    <eLiterals name="YELLOW"/>
    <eLiterals name="BLUE"/>
    <eLiterals name="PURPLE"/>
    <eLiterals name="CYAN"/>
    <eLiterals name="WHITE"/>
